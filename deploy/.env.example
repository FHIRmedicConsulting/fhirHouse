# RoninStandAlone — deployment config. Copy to deploy/.env and edit.
# Secrets: inject via your orchestrator / 1Password `op run` — do NOT commit a real .env.
# Full reference + grouping: docs/standalone/configuration.md. Security detail: the runbook
# (docs/standalone/security-hardening-and-deployment.md).

# ─── Storage (the one knob that switches local vs cloud) ──────────────────────
RONIN_DELTA_BASE=/data/delta
#   RONIN_DELTA_BASE=s3://my-bucket/ronin   (or gs://… / az://…) — sidecar writes Delta directly
RONIN_STORAGE_MODE=single                   # single (default) | medallion (Gold-read WIP — single only for serving)

# ─── Object-store credentials (only when RONIN_DELTA_BASE is a cloud URI) ─────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_ALLOW_UNSAFE_RENAME=                 # true on native AWS S3 (single-writer, ADR-0026); empty for R2/MinIO/GCS
GOOGLE_SERVICE_ACCOUNT=
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=

# ─── Server ───────────────────────────────────────────────────────────────────
RONIN_PORT=3000
RONIN_PUBLIC_URL=http://localhost:3000      # externally-reachable base URL (used in FHIR links)
RONIN_LOG_LEVEL=info

# ─── Security profile (ADR-0032) ──────────────────────────────────────────────
# dev (default): controls opt-in/off, SYNTHETIC data only, warns but never blocks.
# production: FAILS CLOSED unless auth + audit + transport security below are set.
RONIN_SECURITY_PROFILE=dev

# ─── Transport security / TLS (ADR-0031) ──────────────────────────────────────
# Terminate TLS at a proxy/LB (recommended) and attest it:
RONIN_TLS_TERMINATED_AT_PROXY=              # true if a proxy terminates TLS
# …OR run in-process HTTPS (hardened SP 800-52r2) with mounted PEM paths:
RONIN_TLS_CERT=
RONIN_TLS_KEY=
RONIN_TLS_CIPHERS=                          # advanced: override the TLS 1.2 cipher allow-list

# ─── Authentication (ADR-0030) ────────────────────────────────────────────────
RONIN_AUTH_ENABLED=                         # true to enable the SMART/JWT gate (required in production)
RONIN_AUTH_STRATEGY=jwks                    # jwks | oidc | local (verify our own OAuth server) | stub (tests)
RONIN_JWKS_URI=                             # jwks strategy: the IdP's JWKS URL
RONIN_JWT_PUBLIC_KEY=                       # or a static public key (PEM)
RONIN_JWT_ISSUER=
RONIN_JWT_AUDIENCE=
RONIN_JWT_ALG=
RONIN_OIDC_DISCOVERY=                       # oidc strategy: the issuer's .well-known/openid-configuration
RONIN_SMART_VERSIONS=                       # e.g. 2.0.0,2.2.0 (default: all supported)
RONIN_SMART_AUTHORIZE_URL=                  # advertised in .well-known/smart-configuration (if external AS)
RONIN_SMART_TOKEN_URL=

# ─── SMART authorization server (optional; we can issue tokens) ────────────────
RONIN_OAUTH_ENABLED=                        # true to run /oauth/authorize + /oauth/token + JWKS
RONIN_OAUTH_PRIVATE_KEY=                    # STATIC signing keys (PEM) — REQUIRED in production (no ephemeral)
RONIN_OAUTH_PUBLIC_KEY=
RONIN_OAUTH_CLIENTS=                        # JSON array of registered clients (locks down client_id + redirects)
RONIN_OAUTH_DEFAULT_PATIENT=               # dev auto-approve launch context
RONIN_OAUTH_DEFAULT_USER=

# ─── UDAP B2B trust (ADR-0036; opt-in) ─────────────────────────────────────────
RONIN_UDAP_ENABLED=                         # true to enable .well-known/udap + trusted DCR
RONIN_UDAP_TRUST_ANCHORS=                   # comma-separated PEM paths of trusted CA anchors
RONIN_UDAP_REVOKED_CERTS=                   # comma-separated revoked cert SHA-256 fingerprints and/or serials
RONIN_UDAP_REVOKED_CERTS_FILE=              # ...or a file of them (one per line, # comments)

# ─── Audit + consent (ADR-0016/0030/0035) ──────────────────────────────────────
RONIN_AUDIT_ENABLED=                        # true to capture AuditEvents (hash-chained) (required in production)
RONIN_CONSENT_ENFORCEMENT=                  # true to enforce consent/DS4P at read time
RONIN_AUDIT_ANCHOR_INTERVAL_MIN=            # publish signed audit chain-tip anchors every N min (external tamper detection)
RONIN_AUDIT_ANCHOR_WEBHOOK=                 # external append-only sink URL to POST anchors to
RONIN_AUDIT_ANCHOR_KEY=                     # PEM (PKCS8) key to SIGN anchors (optional)

# ─── HTTP hardening (ADR-0033) ─────────────────────────────────────────────────
RONIN_CORS_ORIGINS=                         # comma-separated allowlist (prod + empty = same-origin only)
RONIN_RATE_LIMIT_ENABLED=                   # true to rate-limit (default on in production)
RONIN_RATE_LIMIT_RPM=600                    # requests per client per minute
RONIN_MAX_BODY_BYTES=10485760               # request body cap (10 MiB)

# ─── Storage maintenance (optional) ────────────────────────────────────────────
RONIN_MAINTENANCE_INTERVAL_MIN=             # OPTIMIZE on an interval (empty = off)
RONIN_VACUUM_ENABLED=                       # also VACUUM during maintenance
RONIN_VACUUM_RETENTION_HOURS=               # VACUUM retention window
RONIN_EXPORT_DIR=                           # dir for async $export NDJSON output
