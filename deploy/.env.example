# fhirEngine — deployment config. Copy to deploy/.env and edit.
# Secrets: inject via your orchestrator / 1Password `op run` — do NOT commit a real .env.
# Full reference + grouping: docs/standalone/configuration.md. Security detail: the runbook
# (docs/standalone/security-hardening-and-deployment.md).

# ─── Storage (the one knob that switches local vs cloud) ──────────────────────
FHIRENGINE_DELTA_BASE=/data/delta
#   FHIRENGINE_DELTA_BASE=s3://my-bucket/fhirengine   (or gs://… / az://…) — sidecar writes Delta directly
FHIRENGINE_STORAGE_MODE=single                   # single (default, read-after-write) | medallion (Bronze ingest, Gold serving via external promotion)

# ─── Object-store credentials (only when FHIRENGINE_DELTA_BASE is a cloud URI) ─────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_ALLOW_UNSAFE_RENAME=                 # true on native AWS S3 (single-writer, ADR-0026); empty for R2/MinIO/GCS
AWS_ENDPOINT_URL=                           # S3-compatible stores only (MinIO/R2): the endpoint, e.g. http://localhost:9000
AWS_ENDPOINT=                               # same value as AWS_ENDPOINT_URL (older object_store reads this name)
AWS_ALLOW_HTTP=                             # true when the endpoint is plain http:// (local MinIO)
GOOGLE_SERVICE_ACCOUNT=
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=

# ─── Server ───────────────────────────────────────────────────────────────────
FHIRENGINE_PORT=3000
FHIRENGINE_PUBLIC_URL=http://localhost:3000      # externally-reachable base URL (used in FHIR links)
FHIRENGINE_LOG_LEVEL=info

# ─── Validation ────────────────────────────────────────────────────────────────
# Conformance-profile requirement for incoming resources. Empty (default) = validate against
# the installed FHIR version only (structure, invariants, base bindings); meta.profile claims
# are stored but NOT enforced. Comma-separated entries, each one of:
#   an installed IG package id  (e.g. hl7.fhir.us.core — enforce its profile per resource type)
#   a profile canonical URL     (e.g. http://hl7.org/fhir/us/core/StructureDefinition/us-core-patient)
#   declared                    (enforce whatever profiles each resource claims in meta.profile)
FHIRENGINE_VALIDATION_PROFILES=

# ─── Security profile (ADR-0032) ──────────────────────────────────────────────
# dev (default): controls opt-in/off, SYNTHETIC data only, warns but never blocks.
# production: FAILS CLOSED unless auth + audit + transport security below are set.
FHIRENGINE_SECURITY_PROFILE=dev

# ─── Transport security / TLS (ADR-0031) ──────────────────────────────────────
# Terminate TLS at a proxy/LB (recommended) and attest it:
FHIRENGINE_TLS_TERMINATED_AT_PROXY=              # true if a proxy terminates TLS
# …OR run in-process HTTPS (hardened SP 800-52r2) with mounted PEM paths:
FHIRENGINE_TLS_CERT=
FHIRENGINE_TLS_KEY=
FHIRENGINE_TLS_CIPHERS=                          # advanced: override the TLS 1.2 cipher allow-list

# ─── Authentication (ADR-0030) ────────────────────────────────────────────────
FHIRENGINE_AUTH_ENABLED=                         # true to enable the SMART/JWT gate (required in production)
FHIRENGINE_AUTH_STRATEGY=jwks                    # jwks | oidc | local (verify our own OAuth server) | stub (tests)
FHIRENGINE_JWKS_URI=                             # jwks strategy: the IdP's JWKS URL
FHIRENGINE_JWT_PUBLIC_KEY=                       # or a static public key (PEM)
FHIRENGINE_JWT_ISSUER=
FHIRENGINE_JWT_AUDIENCE=
FHIRENGINE_JWT_ALG=
FHIRENGINE_OIDC_DISCOVERY=                       # oidc strategy: the issuer's .well-known/openid-configuration
FHIRENGINE_SMART_VERSIONS=                       # e.g. 2.0.0,2.2.0 (default: all supported)
FHIRENGINE_SMART_AUTHORIZE_URL=                  # advertised in .well-known/smart-configuration (if external AS)
FHIRENGINE_SMART_TOKEN_URL=

# ─── SMART authorization server (optional; we can issue tokens) ────────────────
FHIRENGINE_OAUTH_ENABLED=                        # true to run /oauth/authorize + /oauth/token + JWKS
FHIRENGINE_OAUTH_PRIVATE_KEY=                    # STATIC signing keys (PEM) — REQUIRED in production (no ephemeral)
FHIRENGINE_OAUTH_PUBLIC_KEY=
FHIRENGINE_OAUTH_CLIENTS=                        # JSON array of registered clients (locks down client_id + redirects)
FHIRENGINE_OAUTH_DEFAULT_PATIENT=               # dev auto-approve launch context
FHIRENGINE_OAUTH_DEFAULT_USER=

# ─── UDAP B2B trust (ADR-0036; opt-in) ─────────────────────────────────────────
FHIRENGINE_UDAP_ENABLED=                         # true to enable .well-known/udap + trusted DCR
FHIRENGINE_UDAP_TRUST_ANCHORS=                   # comma-separated PEM paths of trusted CA anchors
FHIRENGINE_UDAP_REVOKED_CERTS=                   # comma-separated revoked cert SHA-256 fingerprints and/or serials
FHIRENGINE_UDAP_REVOKED_CERTS_FILE=              # ...or a file of them (one per line, # comments)
FHIRENGINE_UDAP_SERVER_KEY=                      # PEM (PKCS8) key to sign .well-known/udap signed_metadata
FHIRENGINE_UDAP_SERVER_CERT=                     # PEM cert chain (leaf-first) for the signed_metadata x5c header
FHIRENGINE_UDAP_CRL_CHECK=                       # true to enable live CRL revocation (downloads + verifies the CRL)
FHIRENGINE_UDAP_CRL_URLS=                        # extra/override CRL URLs (comma-sep); else the cert's CRL Distribution Point
FHIRENGINE_UDAP_CRL_HARD_FAIL=                   # true to REJECT when a CRL can't be fetched/verified (default: soft-fail)
FHIRENGINE_UDAP_OCSP_CHECK=                      # true to enable live OCSP revocation (RFC 6960; queries the responder)
FHIRENGINE_UDAP_OCSP_URLS=                       # extra/override OCSP responder URLs (comma-sep); else the cert's AIA
FHIRENGINE_UDAP_OCSP_HARD_FAIL=                  # true to REJECT when the OCSP responder is unreachable (default: soft-fail)
FHIRENGINE_UDAP_STRICT_PATH=                     # RFC 5280 path validation (basic constraints/key usage/name constraints) — on by default; set false to disable

# ─── Audit + consent (ADR-0016/0030/0035) ──────────────────────────────────────
FHIRENGINE_AUDIT_ENABLED=                        # true to capture AuditEvents (hash-chained) (required in production)
FHIRENGINE_CONSENT_ENFORCEMENT=                  # true to enforce consent/DS4P at read time
FHIRENGINE_AUDIT_ANCHOR_INTERVAL_MIN=            # publish signed audit chain-tip anchors every N min (external tamper detection)
FHIRENGINE_AUDIT_ANCHOR_WEBHOOK=                 # external append-only sink URL to POST anchors to
FHIRENGINE_AUDIT_ANCHOR_KEY=                     # PEM (PKCS8) key to SIGN anchors (optional)

# ─── HTTP hardening (ADR-0033) ─────────────────────────────────────────────────
FHIRENGINE_CORS_ORIGINS=                         # comma-separated allowlist (prod + empty = same-origin only)
FHIRENGINE_RATE_LIMIT_ENABLED=                   # true to rate-limit (default on in production)
FHIRENGINE_RATE_LIMIT_RPM=600                    # requests per client per minute
FHIRENGINE_RATE_LIMIT_STORE=                     # 'redis' for shared limits across instances (needs `npm i ioredis`); else per-node
FHIRENGINE_REDIS_URL=                            # redis://… when FHIRENGINE_RATE_LIMIT_STORE=redis
FHIRENGINE_MAX_BODY_BYTES=10485760               # request body cap (10 MiB)

# ─── Storage maintenance (optional) ────────────────────────────────────────────
FHIRENGINE_MAINTENANCE_INTERVAL_MIN=             # OPTIMIZE on an interval (empty = off)
FHIRENGINE_VACUUM_ENABLED=                       # also VACUUM during maintenance
FHIRENGINE_VACUUM_RETENTION_HOURS=               # VACUUM retention window
FHIRENGINE_EXPORT_DIR=                           # dir for async bulk-export NDJSON output (no "$": compose interpolates it)
