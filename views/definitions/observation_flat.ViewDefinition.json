{
  "resourceType": "ViewDefinition",
  "name": "observation_flat",
  "title": "Observations, one row per coding (demonstrates getReferenceKey, ofType, forEach)",
  "status": "draft",
  "resource": "Observation",
  "select": [
    {
      "column": [
        { "name": "observation_id", "path": "getResourceKey()", "type": "id" },
        { "name": "status", "path": "status", "type": "code" },
        { "name": "patient_id", "path": "subject.getReferenceKey(Patient)", "type": "id" },
        { "name": "effective_dt", "path": "effective.ofType(dateTime)", "type": "dateTime" },
        { "name": "value_quantity", "path": "value.ofType(Quantity).value", "type": "decimal" },
        { "name": "value_unit", "path": "value.ofType(Quantity).unit", "type": "string" }
      ]
    },
    {
      "forEach": "code.coding",
      "column": [
        { "name": "code_system", "path": "system", "type": "uri" },
        { "name": "code", "path": "code", "type": "code" },
        { "name": "code_display", "path": "display", "type": "string" }
      ]
    }
  ]
}
