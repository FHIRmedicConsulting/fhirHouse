{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    // Generated code from @atomic-ehr/codegen leaves a few unused imports for
    // future expansion. Don't enforce no-unused-locals on generated output.
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    // DOM is included for `structuredClone` which profile-helpers uses; the
    // .d.ts output has no runtime DOM dependency, so this is type-level only.
    "lib": ["ES2022", "DOM"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
